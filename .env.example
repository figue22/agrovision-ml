# === AgroVision ML Service ===

# General
APP_ENV=development
APP_PORT=8000

# Base de datos (lectura de parcelas, cultivos, clima, actividades)
DATABASE_URL=postgresql://agrovision_user:agrovision_pass_2026@localhost:5432/agrovision_db

# Backend NestJS
BACKEND_API_URL=http://localhost:4000/api/v1

# MLflow (tracking de experimentos)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=agrovision-predictions

# Modelos serializados
MODEL_PATH=./data/models
